# Jira Configuration (Required)
JIRA_SERVER=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# Optional: Custom field ID for Acceptance Criteria in Jira
# JIRA_AC_FIELD=customfield_10001

# Optional: Custom field ID for Pull Request links in Jira
# JIRA_PR_FIELD=customfield_10875

# Optional: Google Drive folder ID to move created docs to a shared folder
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# =============================================================================
# Google Docs/Drive Authentication (NOT environment variables)
# =============================================================================
# Google authentication uses OAuth files, not environment variables:
#
# 1. Download OAuth client ID from Google Cloud Console
#    Save as: credentials.json
#
# 2. Run: python3 auth_setup.py
#    This creates: token.json (auto-generated after browser sign-in)
#
# See README.md for detailed setup instructions.
